IotSystem ConnectedHeater {
	currentTime 0
	ownedActor {
		Actor Thermometer {
			isSensible 1
			processTime 4
			periodTime 25
			currentProcessTime 0
			resource "CPU"
		},
		Actor HeatingDevice {
			isSensible 0
			processTime 7
			periodTime 35
			currentProcessTime 0
			resource "CPU"
		},
		Actor Monitor {
			isSensible 0
			processTime 1
			periodTime 15
			currentProcessTime 0
			resource "CPU"
		}
	}
	ownedResource {
		Resource CPU {
            actor (Thermometer, HeatingDevice, Monitor)
        }
	}
}